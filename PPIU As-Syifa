        // State variables
        let currentBookPage = 1; 
        let isBookDarkMode = false;
        let bookBookmarks = [];
        let formFeedbackRating = 5;

        // Custom Toast Notification Function
        function showToast(message, type = "success") {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `px-5 py-3 rounded-xl border text-xs font-bold shadow-xl flex items-center gap-2.5 transition-all duration-300 translate-y-2 opacity-0 pointer-events-auto`;
            
            if (type === "success") {
                toast.className += ` bg-neutral-900 border-gold-premium text-white`;
                toast.innerHTML = `<i class="fa-solid fa-circle-check text-gold-premium"></i> ${message}`;
            } else {
                toast.className += ` bg-red-950 border-red-800 text-red-200`;
                toast.innerHTML = `<i class="fa-solid fa-circle-exclamation text-red-400"></i> ${message}`;
            }

            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 50);

            // Remove Toast
            setTimeout(() => {
                toast.classList.add('translate-y-2', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Mobile Menu Toggle
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileBtn && mobileMenu) {
            mobileBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });
            // Auto close mobile links on click
            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                });
            });
        }

        // Header Background effect on scroll
        const mainHeader = document.getElementById('main-header');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                mainHeader.classList.add('bg-neutral-950/95', 'py-1');
                mainHeader.classList.remove('bg-neutral-900/85', 'py-0');
            } else {
                mainHeader.classList.remove('bg-neutral-950/95', 'py-1');
                mainHeader.classList.add('bg-neutral-900/85', 'py-0');
            }
        });

        // Initialize Digital Book Reader
        function renderBookPage() {
            const pageData = manasikBookPages[currentBookPage - 1];
            const contentContainer = document.getElementById('book-content-container');
            const pageIndicator = document.getElementById('book-page-indicator');
            const progressFill = document.getElementById('book-reading-progress');
            const progressPct = document.getElementById('book-reading-percentage');
            const bookmarkIcon = document.getElementById('bookmark-icon');

            if (!contentContainer) return;

            // Render content
            contentContainer.innerHTML = `
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-gold-premium">${pageData.chapter}</span>
                    <span class="text-[10px] text-gray-500 font-bold uppercase">Panduan Praktis Haji & Umrah</span>
                </div>
                <h3 class="text-2xl font-serif font-extrabold text-white mb-4" id="reader-heading-title">${pageData.title}</h3>
                <div class="prose prose-invert max-w-none text-gray-300">
                    ${pageData.content}
                </div>
            `;

            // Update page indicator & progress bar
            pageIndicator.innerText = `Halaman ${currentBookPage} / ${manasikBookPages.length}`;
            const percentage = Math.round((currentBookPage / manasikBookPages.length) * 100);
            progressFill.style.width = `${percentage}%`;
            progressPct.innerText = `${percentage}%`;

            // Adjust Bookmarking Icon state
            if (bookBookmarks.includes(currentBookPage)) {
                bookmarkIcon.className = "fa-solid fa-bookmark text-gold-premium";
            } else {
                bookmarkIcon.className = "fa-regular fa-bookmark text-gray-300";
            }

            // Sync night/day background theme styling
            const bookCanvas = document.getElementById('book-canvas');
            const titleHeading = document.getElementById('reader-heading-title');
            if (isBookDarkMode) {
                bookCanvas.style.backgroundColor = '#f7f7f7';
                titleHeading.style.color = '#0c0c0c';
                contentContainer.querySelectorAll('p, li').forEach(el => el.style.color = '#2d2d2d');
            } else {
                bookCanvas.style.backgroundColor = '#050505';
                titleHeading.style.color = '#ffffff';
                contentContainer.querySelectorAll('p, li').forEach(el => el.style.color = '#d1d5db');
            }
        }

        // Turn book page
        function changeBookPage(direction) {
            let targetPage = currentBookPage + direction;
            if (targetPage >= 1 && targetPage <= manasikBookPages.length) {
                currentBookPage = targetPage;
                renderBookPage();
                showToast(`Membuka halaman ${currentBookPage}`);
            } else {
                showToast("Anda telah berada di halaman batas akhir.", "error");
            }
        }

        // Toggle Bookmark state for current page
        function toggleBookmarkCurrentPage() {
            const idx = bookBookmarks.indexOf(currentBookPage);
            if (idx > -1) {
                bookBookmarks.splice(idx, 1);
                showToast(`Halaman ${currentBookPage} dihapus dari bookmark.`);
            } else {
                bookBookmarks.push(currentBookPage);
                const alertBanner = document.getElementById('bookmark-alert');
                alertBanner.classList.remove('hidden');
                setTimeout(() => alertBanner.classList.add('hidden'), 2500);
            }
            renderBookPage();
        }

        function hideBookmarkAlert() {
            document.getElementById('bookmark-alert').classList.add('hidden');
        }

        // Toggle Day/Night Reader Theme
        function toggleReaderTheme() {
            isBookDarkMode = !isBookDarkMode;
            const badge = document.getElementById('reading-mode-badge');
            if (isBookDarkMode) {
                badge.innerHTML = `<i class="fa-solid fa-moon text-indigo-500"></i> Mode Gelap`;
                showToast("Membuka tampilan kontras tinggi kertas terang.");
            } else {
                badge.innerHTML = `<i class="fa-solid fa-sun text-gold-premium"></i> Mode Terang`;
                showToast("Kembali ke tampilan standar malam.");
            }
            renderBookPage();
        }

        // Search reader text content simple simulation
        const searchInput = document.getElementById('book-search-input');
        if (searchInput) {
            searchInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    const query = searchInput.value.toLowerCase().trim();
                    if (!query) return;

                    // Search matches
                    let foundPageIndex = -1;
                    for (let i = 0; i < manasikBookPages.length; i++) {
                        const rawText = (manasikBookPages[i].title + " " + manasikBookPages[i].content).toLowerCase();
                        if (rawText.includes(query)) {
                            foundPageIndex = i + 1;
                            break;
                        }
                    }

                    if (foundPageIndex > -1) {
                        currentBookPage = foundPageIndex;
                        renderBookPage();
                        showToast(`Ditemukan materi kata '${query}' di halaman ${foundPageIndex}!`);
                    } else {
                        showToast(`Materi pencarian '${query}' tidak ditemukan.`, "error");
                    }
                }
            });
        }

        // Scroll helper (MODIFIED to open modal directly instead of scrolling to bottom)
        function openDigitalReader() {
            const modal = document.getElementById('digital-reader-modal');
            if (modal) {
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden'; // Lock background scroll
                renderBookPage();
                showToast("Membuka Panduan Manasik Digital...");
            }
        }

        function closeDigitalReader() {
            const modal = document.getElementById('digital-reader-modal');
            if (modal) {
                modal.classList.add('hidden');
                document.body.style.overflow = ''; // Unlock background scroll
                showToast("Menutup Panduan Manasik.");
            }
        }

        // Close modal on Escape key press
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeDigitalReader();
                closeVideoPlayer();
