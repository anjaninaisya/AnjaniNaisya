        // Filter Masonry Media Gallery
        function filterGallery(category) {
            const items = document.querySelectorAll('.gallery-item');
            const btns = document.querySelectorAll('.gallery-filter-btn');

            // Toggle filter button styling
            btns.forEach(btn => {
                const text = btn.innerText.toLowerCase();
                const isMatch = (category === 'semua' && text.includes('semua')) || 
                                (category === 'manasik' && text.includes('bimbingan')) ||
                                (category === 'alqosbah' && text.includes('alqosbah')) ||
                                (category === 'bagasi' && text.includes('koper')) ||
                                (category === 'rapat' && text.includes('panitia')) ||
                                (category === 'makkah' && text.includes('makkah')) ||
                                (category === 'madinah' && text.includes('madinah'));
                
                if (isMatch) {
                    btn.className = "gallery-filter-btn px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-all bg-gold-premium text-black shadow-md";
                } else {
                    btn.className = "gallery-filter-btn px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider transition-all text-gray-400 hover:text-white bg-neutral-900";
                }
            });

            // Filter items layout
            let matchCount = 0;
            items.forEach(item => {
                if (category === 'semua' || item.classList.contains(category)) {
                    item.classList.remove('hidden');
                    matchCount++;
                } else {
                    item.classList.add('hidden');
                }
            });

            showToast(`Menampilkan ${matchCount} dokumentasi foto.`);
        }

        // Rating Form Star Selection
        function selectFormRating(stars) {
            formFeedbackRating = stars;
            const starContainer = document.getElementById('rating-stars-container');
            const buttons = starContainer.querySelectorAll('button');

            buttons.forEach((btn, index) => {
                if (index < stars) {
                    btn.className = "text-2xl text-gold-premium transition-all";
                } else {
                    btn.className = "text-2xl text-gray-600 hover:text-gold-premium transition-all";
                }
            });
        }

        // Live Submit Pilgrim Satisfaction Feedback Form
        let baseRespondentCount = 1842;
        let baseTotalRatingScore = 1842 * 9.7; // Simulating cumulative rating averages

        function submitPilgrimFeedback(event) {
            event.preventDefault();

            const name = document.getElementById('feedback-name').value;
            const comments = document.getElementById('feedback-comments').value;

            if (!name || !comments) {
                showToast("Harap lengkapi seluruh kolom formulir.", "error");
                return;
            }

            // Recalculate Dashboard Stats dynamically!
            baseRespondentCount++;
            baseTotalRatingScore += (formFeedbackRating * 2); // mapping 5 stars to 10 points system
            const newAvg = (baseTotalRatingScore / baseRespondentCount).toFixed(1);

            // Update DOM metrics
            document.getElementById('stat-respondent-count').innerText = baseRespondentCount.toLocaleString('id-ID');
            document.getElementById('stat-rating-text').innerText = newAvg;

            // Recalculate Circle SVG Gauge offset
            const strokeDashoffset = Math.round(471 - (471 * (newAvg / 10)));
            document.getElementById('stat-gauge-circle').style.strokeDashoffset = strokeDashoffset;

            // Show Custom Thank You Toast
            showToast(`Terima kasih Bapak/Ibu ${name}, umpan balik berhasil di-posting pada sistem kami.`);

            // Clear inputs
            document.getElementById('feedback-form').reset();
            selectFormRating(5); // reset star
        }

        // On Window Load Initialization
        window.onload = function () {
            // Pre-select first area in Plaza map
            selectFloorArea(1);
        }
